{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start -b swc",
    "start:dev": "nest start -b swc --watch",
    "start:debug": "nest start -b swc --debug --watch",
    "start:prod": "node dist/main",
    "seed:users": "ts-node -r tsconfig-paths/register src/seed-users.ts",
    "seed:users:prod": "node dist/seed-users.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "test:agent-live": "printf 'Run from repo root with: nvm use && cd server && FINAI_AGENT_LIVE_TESTS=true OPENAI_BASE_URL=... OPENAI_API_KEY=... npm run test:agent-live\\n' && vitest run --config ./vitest.config.agent-live.ts"
  },
  "dependencies": {
    "@langchain/core": "1.1.48",
    "@langchain/langgraph-checkpoint-postgres": "1.0.2",
    "@langchain/openai": "1.4.7",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "2.1.1",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "11.0.1",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "csv-stringify": "6.7.0",
    "langchain": "1.4.4",
    "multer": "2.1.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "8.21.0",
    "pg-boss": "12.18.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "0.3.30",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.40",
    "@types/bcrypt": "6.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "2.1.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "chokidar": "5.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "30.4.2",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "7.2.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
